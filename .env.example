# wonseok-han Portfolio - Environment Variables
#
# 사용법:
#   1) 이 파일을 `.env.local`로 복사 (gitignored)
#        cp .env.example .env.local
#   2) 값 채운 뒤 `pnpm dev` 실행
#
# 주의: NEXT_PUBLIC_* 접두어가 붙은 변수만 브라우저에 노출됨.

# ===== Contact Form (Resend) =====
# https://resend.com — 포트폴리오 Contact 폼 이메일 발송용.
# API Key: Dashboard > API Keys 에서 생성.
CONTACT_EMAIL=your-email@example.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== AWS S3 (데이터 저장소) =====
# 포트폴리오 JSON 데이터(경력, 프로젝트 등)를 S3에서 로드.
# IAM > Access Keys 에서 발급.
S3_BUCKET_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
S3_BUCKET_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-bucket-name
SR_BUCKET_URL=https://your-bucket-name.s3.ap-northeast-2.amazonaws.com/portfolio

# ===== App =====
# BFF(API Route) 호출 시 사용할 origin. 미설정 시 요청 헤더에서 자동 추출.
NEXT_PUBLIC_BASE_URL=https://your-domain.com
